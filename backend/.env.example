# ─────────────────────────────────────────────────────────────────────────────
# CrimeRakshak FastAPI Backend Environment Configuration (.env.example)
# Copy this file to .env and populate the required secret values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. Application & Environment (REQUIRED) ──
PROJECT_NAME="Graph Intelligence & Security Service"
ENVIRONMENT=production
API_V1_PREFIX=/api/v1

# ── 2. Security & Auth Secrets (SECRETS - REQUIRED IN PRODUCTION) ──
# Generate a strong 256-bit secret key: `openssl rand -hex 32`
SECRET_KEY=generate_a_random_32_byte_hex_string_for_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_LEEWAY_SECONDS=10

# Clerk Authentication Secret (Required if Clerk Auth is enabled)
CLERK_SECRET_KEY=sk_live_or_test_your_clerk_backend_secret_key

# ── 3. Database Configuration (REQUIRED) ──
# PostgreSQL / PostGIS database connection URL
# Render PostgreSQL Internal URL format: postgresql://user:password@dpg-xxxx-a:5432/db_name
POSTGRES_URI=postgresql://user:password@localhost:5432/crimerakshak

# ── 4. Neo4j Graph Database (OPTIONAL / FEATURE-FLAGGED) ──
# Set USE_NEO4J=False if Neo4j graph instance is not provisioned
USE_NEO4J=False
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
GRAPH_MAX_NODES=500
GRAPH_DEFAULT_LIMIT=100
GRAPH_MAX_DEPTH=5

# ── 5. AI / LLM Provider Configuration (OPTIONAL) ──
# Provider: "gemini" or "openrouter"
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_AGENT_MODEL=gemini-flash-lite-latest
LLM_SUMMARY_MODEL=gemini-flash-lite-latest
LLM_MAX_TOKENS=1024

OPENROUTER_API_KEY=your_openrouter_api_key_if_using_openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── 6. CSV & DuckDB Analytics (REQUIRED) ──
DATASETS_DIR=../datasets
DUCKDB_PATH=crime_stats.duckdb

# ── 7. Security Policy (REQUIRED) ──
PASSWORD_MIN_LENGTH=8
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# ── 8. Cross-Origin Resource Sharing (CORS - REQUIRED FOR FRONTEND) ──
# Comma-separated list of allowed frontend origins (Vercel, Render, or custom domains)
BACKEND_CORS_ORIGINS=["https://crimerakshak.onrender.com","https://crimerakshak.vercel.app","http://localhost:3000"]
